# =============================================================================
# Shared / repo root — copy to `.env` and adjust (never commit real `.env`)
# =============================================================================

# --- Database & auth (backend) ---
DATABASE_URL=postgresql://user:pass@host:5432/dbname
DATABASE_SSL=true
JWT_SECRET=use-a-long-random-string-in-production
JWT_EXPIRES_IN=7d
NODE_ENV=development

# --- Backend HTTP ---
PORT=3001

# Public URL of this API (optional; used in startup logs). No trailing slash.
# Example: https://your-api.onrender.com
BACKEND_URL=

# Browser origin(s) of your SPA — required for CORS. No trailing slashes.
# Single:   FRONTEND_URL=https://your-app.vercel.app
# Multiple: FRONTEND_URL=https://app.com,https://www.app.com
# Legacy alias: CORS_ORIGIN (same value as FRONTEND_URL if you prefer)
FRONTEND_URL=http://localhost:5173

# When the SPA and API are on different sites, cookies must be cross-site.
# Set to `true` in production with HTTPS on both sides.
# Also set TRUST_PROXY=true if the API sits behind a reverse proxy (Render, etc.).
CROSS_ORIGIN_COOKIES=false
TRUST_PROXY=false

# Optional overrides (defaults work for most cases):
# COOKIE_SAME_SITE=lax
# COOKIE_SECURE=false

# --- Local dev: Vite proxy target (where /api is forwarded) ---
VITE_DEV_PROXY_TARGET=http://localhost:3001

# --- Frontend build (Vite) — set when building for production hosting ---
# Must match your deployed API origin. No trailing slash.
# Leave empty for local dev (uses same-origin /api via proxy).
VITE_BACKEND_URL=
